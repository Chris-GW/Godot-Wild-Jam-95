; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Godot Wild Jam #95"
config/version="0.1.0"
config/tags=PackedStringArray("game_jam", "godot_wild_jam", "team")
run/main_scene="uid://d0m5iwcwjpurf"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="uid://c65di63u0ocdn"

[autoload]

CustomLogger="*uid://cfeevg7kmrnf1"
SignalHelper="*uid://dd7o6b24hax4s"
GameEvents="*uid://bkfyrg5npn2sx"
Inventory="*uid://cqcl5ovga5xm0"
Loadout="*uid://dt7wqwylottt6"
BattleManager="*uid://dbv8yau7wdct7"
PlayerManager="*uid://wy214jdh4vgm"
DialogueManager="*uid://c3rodes2l3gxb"
SceneSwitcher="*uid://b8xd55tbw76d4"
SoundManager="*uid://b7khk0p0f50bt"

[dialogue_manager]

runtime/balloon_path="uid://bk8d6x26ydwv3"
runtime/state_autoload_shortcuts=["PlayerManager"]

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/yard/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "red",
"res://assets/": "orange",
"res://resources/": "yellow",
"res://scenes/": "teal",
"res://scripts/": "purple"
}

